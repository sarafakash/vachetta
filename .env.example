# ---- Privy (auth + embedded Solana wallet) ----
# dashboard.privy.io -> create app -> enable Google, Apple, Solana embedded wallets
NEXT_PUBLIC_PRIVY_APP_ID=

# ---- Solana RPC (Alchemy free tier) ----
# alchemy.com -> create Solana app -> copy the https URL (includes key in path)
NEXT_PUBLIC_SOLANA_RPC=https://api.mainnet-beta.solana.com

# ---- BirdEye (market data) ----
# birdeye.so/data-api -> Standard (free) plan -> API key
# server-only: never exposed to the client, proxied through /api/birdeye
BIRDEYE_API_KEY=

# ---- Supabase (profiles, networth snapshots, activity) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
